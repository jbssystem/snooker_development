{
  "name": "snooker-player-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev:web": "pnpm --filter @snooker/web dev",
    "dev:api": "pnpm --filter @snooker/api start:dev",
    "dev:worker": "pnpm --filter @snooker/worker dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "seed:demo": "pnpm --filter @snooker/api seed:demo",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test:ui": "playwright test --project=smoke",
    "test:ui:headed": "playwright test --project=smoke --headed",
    "test:ui:debug": "playwright test --project=smoke --ui",
    "test:ui:e2e": "playwright test --project=e2e",
    "test:ui:report": "playwright show-report"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
