# ===== App =====
NODE_ENV=development
APP_NAME=snooker-player-os
DEFAULT_LOCALE=ru

# ===== Web =====
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===== API =====
API_PORT=4000
API_JWT_SECRET=change-me-in-production
API_JWT_REFRESH_SECRET=change-me-too

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=snooker_os
POSTGRES_USER=snooker
POSTGRES_PASSWORD=snooker_password
DATABASE_URL=postgresql://snooker:snooker_password@localhost:5433/snooker_os

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== MinIO / S3 =====
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=snooker-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ===== AI =====
# Pluggable LLM provider. Leave empty to disable AI features.
# Supported: anthropic | openai | local | none
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-3-5-sonnet-latest
