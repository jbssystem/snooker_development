# ===== App =====
NODE_ENV=development
APP_NAME=snooker-player-os
DEFAULT_LOCALE=ru

# ===== Web =====
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ===== API =====
API_PORT=4000
API_JWT_SECRET=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost
AUTH_REFRESH_COOKIE_PATH=/auth
AUTH_REFRESH_COOKIE_SECURE=false

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=snooker_os
POSTGRES_USER=snooker
POSTGRES_PASSWORD=snooker_password
DATABASE_URL=postgresql://snooker:snooker_password@localhost:5433/snooker_os

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ===== MinIO / S3 =====
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=snooker-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ===== AI =====
# Pluggable LLM provider. Leave empty to disable AI features.
# Supported: anthropic | openai | local | none
# Photo → ball-map recognition (POST /drill-templates/recognize-layout) requires
# AI_PROVIDER=anthropic, a valid AI_API_KEY, and a vision-capable AI_MODEL
# (e.g. claude-haiku-4-5-20251001 or claude-3-5-sonnet-latest).
AI_PROVIDER=anthropic
AI_API_KEY=
AI_MODEL=claude-3-5-sonnet-latest
# Optional: stronger model used only for photo → ball-map recognition. Spatial
# reasoning (resolving tightly packed reds) is much better on a Sonnet-class model.
# Falls back to AI_MODEL when unset.
AI_VISION_MODEL=claude-sonnet-4-5
# These AI_* vars are now only the FALLBACK. Provider/model/key can be changed at
# runtime from the admin UI (/admin/ai-settings); DB values override these.
# Master secret for encrypting the admin-managed API key at rest (AES-256-GCM).
# Any string works (it is hashed to 32 bytes). Required for the admin key store;
# the API/worker share this value. Rotate on exposure.
SETTINGS_ENC_KEY=

# ===== Email (SMTP) =====
# Leave SMTP_HOST empty in dev — verification links are printed to the API log instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Snooker Player OS <no-reply@example.com>"
# Base URL used to build the email-verification link.
WEB_BASE_URL=http://localhost:3000

# ===== Admin bootstrap =====
# On startup the API ensures a SYSTEM_ADMIN user with these credentials exists.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Administrator
# Set true to re-sync the admin password from env on next boot.
ADMIN_RESET_PASSWORD=false
