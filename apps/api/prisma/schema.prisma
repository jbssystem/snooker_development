// Snooker Player Development OS — Prisma schema (initial skeleton)
// See docs/database-model.md for the full mapping to the TZ entities.
// Migrations are added incrementally per feature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  PENDING_VERIFICATION
  BLOCKED
}

enum RoleType {
  PLAYER
  COACH
  PARENT
  ACADEMY_ADMIN
  SYSTEM_ADMIN
}

enum DominantHand {
  LEFT
  RIGHT
  AMBIDEXTROUS
}

enum DrillCategory {
  CUE_ACTION        @map("cue_action")
  POTTING           @map("potting")
  POSITIONAL_PLAY   @map("positional_play")
  BREAK_BUILDING    @map("break_building")
  SAFETY            @map("safety")
  SNOOKER_ESCAPE    @map("snooker_escape")
  TACTICAL_PLAY     @map("tactical_play")
  MATCH_SIMULATION  @map("match_simulation")
  PRESSURE_TRAINING @map("pressure_training")
  MENTAL_ROUTINE    @map("mental_routine")
  CUSTOM            @map("custom")
}

enum DrillDifficulty {
  BEGINNER     @map("beginner")
  INTERMEDIATE @map("intermediate")
  ADVANCED     @map("advanced")
  PROFESSIONAL @map("professional")
}

enum DrillVisibility {
  PRIVATE @map("private")
  SHARED  @map("shared")
  SYSTEM  @map("system")
}

enum TrainingSessionType {
  SOLO       @map("solo")
  COACHED    @map("coached")
  MATCH_PREP @map("match_prep")
  REVIEW     @map("review")
  OTHER      @map("other")
}

enum DrillAttemptResult {
  SUCCESS @map("success")
  PARTIAL @map("partial")
  MISS    @map("miss")
  SKIPPED @map("skipped")
}

enum MatchResult {
  PLAYER_WIN   @map("player_win")
  OPPONENT_WIN @map("opponent_win")
  DRAW         @map("draw")
  UNKNOWN      @map("unknown")
}

enum MatchSource {
  MANUAL   @map("manual")
  EXTERNAL @map("external")
}

enum FrameWinner {
  PLAYER   @map("player")
  OPPONENT @map("opponent")
  UNKNOWN  @map("unknown")
}

enum MatchType {
  MATCH    @map("match")
  SPARRING @map("sparring")
}

enum CalendarEventType {
  TRAINING         @map("training")
  TOURNAMENT       @map("tournament")
  MATCH            @map("match")
  TRAVEL           @map("travel")
  REST_DAY         @map("rest_day")
  ILLNESS          @map("illness")
  INJURY           @map("injury")
  EQUIPMENT_CHANGE @map("equipment_change")
  COACH_CHANGE     @map("coach_change")
  SUPPLEMENT_START @map("supplement_start")
  SUPPLEMENT_END   @map("supplement_end")
  SLEEP_ISSUE      @map("sleep_issue")
  SCHOOL_WORKLOAD  @map("school_workload")
  CUSTOM_FACTOR    @map("custom_factor")
}

enum CalendarEventSource {
  MANUAL   @map("manual")
  EXTERNAL @map("external")
}

enum AiReportType {
  WEEKLY_SUMMARY     @map("weekly_summary")
  EXTERNAL_ANALYSIS  @map("external_analysis")
}

enum ExternalSource {
  WST         @map("wst")
  CUETRACKER  @map("cuetracker")
}

enum ImportJobStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
}

enum AiReportStatus {
  QUEUED    @map("queued")
  RUNNING   @map("running")
  COMPLETED @map("completed")
  FAILED    @map("failed")
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  passwordHash    String
  displayName     String
  status          UserStatus @default(ACTIVE)
  emailVerifiedAt DateTime?
  blockedAt       DateTime?
  blockedReason   String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  lastLoginAt     DateTime?

  roles                   Role[]
  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  playerProfile           PlayerProfile?
  coachProfile            CoachProfile?
  drillTemplates          DrillTemplate[]         @relation("CreatedDrillTemplates")
  createdTrainingSessions TrainingSession[]       @relation("CreatedTrainingSessions")
  createdMatches          Match[]                 @relation("CreatedMatches")
  createdCalendarEvents   CalendarEvent[]         @relation("CreatedCalendarEvents")
  createdSupplementEvents SupplementEvent[]       @relation("CreatedSupplementEvents")
  requestedAiReports      AiReport[]              @relation("RequestedAiReports")
  authoredAnnouncements   Announcement[]          @relation("AuthoredAnnouncements")
  dismissedAnnouncements  AnnouncementDismissal[]
  adminAuditLogs          AdminAuditLog[]         @relation("AdminAuditActor")
  sensitiveAccessLogs     SensitiveDataAccessLog[] @relation("SensitiveDataActor")
  profileMemberships      ProfileMembership[]
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id        String   @id @default(cuid())
  userId    String
  roleType  RoleType
  scopeType String?
  scopeId   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleType])
}

model PlayerProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  country      String?
  dominantHand DominantHand?
  level        String?
  seasonGoal   String?
  avatar       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  wstId            String?
  cuetrackerId     String?

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment         EquipmentProfile[]
  trainingSessions  TrainingSession[]
  drillExecutions   DrillExecution[]
  matches           Match[]
  calendarEvents    CalendarEvent[]
  lifestyleFactors  LifestyleFactor[]
  supplementEvents  SupplementEvent[]
  aiReports         AiReport[]
  externalLinks     ExternalPlayerLink[]
  sensitiveAccessLogs SensitiveDataAccessLog[]
  memberships       ProfileMembership[]
  invitations       ProfileInvitation[]
}

model EquipmentProfile {
  id              String    @id @default(cuid())
  playerProfileId String
  cueName         String?
  cueWeight       Float?
  tipBrand        String?
  tipSize         Float?
  tipChangeDate   DateTime?
  extension       String?
  chalk           String?
  notes           String?
  activeFrom      DateTime  @default(now())
  activeTo        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([activeFrom])
  @@index([activeTo])
}

model CoachProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  country        String?
  certifications String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DrillTemplate {
  id                     String          @id @default(cuid())
  name                   String
  category               DrillCategory
  difficulty             DrillDifficulty
  description            String
  goal                   String
  rules                  String
  successCriteria        String
  metricsSchemaJson      Json
  defaultTableLayoutJson Json?
  tags                   String[]        @default([])
  visibility             DrillVisibility @default(PRIVATE)
  createdByUserId        String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  createdBy  User             @relation("CreatedDrillTemplates", fields: [createdByUserId], references: [id], onDelete: Cascade)
  executions DrillExecution[]

  @@index([createdByUserId])
  @@index([category])
  @@index([difficulty])
  @@index([visibility])
  @@index([createdAt])
}

model TrainingSession {
  id              String              @id @default(cuid())
  playerProfileId String
  createdByUserId String
  startedAt       DateTime            @default(now())
  endedAt         DateTime?
  sessionType     TrainingSessionType @default(SOLO)
  title           String
  goal            String?
  intensity       Int?
  fatigueBefore   Int?
  fatigueAfter    Int?
  focusLevel      Int?
  mood            String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  playerProfile   PlayerProfile    @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("CreatedTrainingSessions", fields: [createdByUserId], references: [id], onDelete: Cascade)
  drillExecutions DrillExecution[]

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([startedAt])
  @@index([endedAt])
}

model DrillExecution {
  id                      String    @id @default(cuid())
  trainingSessionId       String
  drillTemplateId         String
  playerProfileId         String
  startedAt               DateTime  @default(now())
  endedAt                 DateTime?
  attempts                Int       @default(0)
  successes               Int       @default(0)
  score                   Float?
  maxRun                  Int?
  averageScore            Float?
  resultJson              Json?
  errorTags               String[]  @default([])
  coachNotes              String?
  playerNotes             String?
  tableLayoutSnapshotJson Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  drillTemplate   DrillTemplate   @relation(fields: [drillTemplateId], references: [id], onDelete: Restrict)
  playerProfile   PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  attemptsLog     DrillAttempt[]

  @@index([trainingSessionId])
  @@index([drillTemplateId])
  @@index([playerProfileId])
  @@index([startedAt])
  @@index([endedAt])
}

model DrillAttempt {
  id               String             @id @default(cuid())
  drillExecutionId String
  attemptNumber    Int
  result           DrillAttemptResult
  score            Float?
  potSuccess       Boolean?
  positionSuccess  Boolean?
  missType         String?
  errorTags        String[]           @default([])
  shotTimeMs       Int?
  notes            String?
  createdAt        DateTime           @default(now())

  drillExecution DrillExecution @relation(fields: [drillExecutionId], references: [id], onDelete: Cascade)

  @@unique([drillExecutionId, attemptNumber])
  @@index([drillExecutionId])
  @@index([createdAt])
}

model Match {
  id                  String       @id @default(cuid())
  playerProfileId     String
  createdByUserId     String
  matchDate           DateTime     @default(now())
  matchType           MatchType    @default(MATCH)
  isLive              Boolean      @default(false)
  tournament          String?
  country             String?
  city                String?
  club                String?
  opponentName        String
  opponentExternalId  String?
  round               String?
  format              String?
  framesWon           Int          @default(0)
  framesLost          Int          @default(0)
  highBreak           Int?
  breaks50            Int          @default(0)
  breaks70            Int          @default(0)
  breaks100           Int          @default(0)
  decidingFrameResult FrameWinner?
  safetySuccess       Float?
  longPotSuccess      Float?
  unforcedErrors      Int?
  tacticalErrors      Int?
  result              MatchResult  @default(UNKNOWN)
  source              MatchSource  @default(MANUAL)
  sourceUrl           String?
  externalImportJobId String?
  videoUrl            String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("CreatedMatches", fields: [createdByUserId], references: [id], onDelete: Cascade)
  frames        MatchFrame[]

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([matchDate])
  @@index([opponentName])
  @@index([result])
  @@index([matchType])
}

model MatchFrame {
  id               String      @id @default(cuid())
  matchId          String
  frameNumber      Int
  playerScore      Int?
  opponentScore    Int?
  winner           FrameWinner @default(UNKNOWN)
  highBreak        Int?
  frameDurationSec Int?
  notes            String?
  scoreEvents      Json?
  createdAt        DateTime    @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, frameNumber])
  @@index([matchId])
  @@index([winner])
}

model CalendarEvent {
  id              String              @id @default(cuid())
  playerProfileId String
  createdByUserId String
  eventType       CalendarEventType
  title           String
  description     String?
  startAt         DateTime            @default(now())
  endAt           DateTime?
  source          CalendarEventSource @default(MANUAL)
  metadataJson    Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("CreatedCalendarEvents", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([eventType])
  @@index([startAt])
  @@index([source])
}

model LifestyleFactor {
  id              String   @id @default(cuid())
  playerProfileId String
  date            DateTime
  sleepHours      Float?
  sleepQuality    Int?
  fatigue         Int?
  stress          Int?
  focus           Int?
  mood            String?
  illness         Boolean  @default(false)
  injury          Boolean  @default(false)
  travel          Boolean  @default(false)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@unique([playerProfileId, date])
  @@index([playerProfileId])
  @@index([date])
}

model SupplementEvent {
  id              String    @id @default(cuid())
  playerProfileId String
  createdByUserId String
  name            String
  category        String?
  startDate       DateTime
  endDate         DateTime?
  dosageNote      String?
  reason          String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("CreatedSupplementEvents", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([name])
  @@index([startDate])
  @@index([endDate])
}

model AiReport {
  id                String         @id @default(cuid())
  playerProfileId   String
  requestedByUserId String
  reportType        AiReportType   @default(WEEKLY_SUMMARY)
  status            AiReportStatus @default(QUEUED)
  periodStart       DateTime
  periodEnd         DateTime
  locale            String         @default("ru")
  title             String?
  contentMarkdown   String?
  sourceDataHash    String
  sourceDataJson    Json
  dataSourcesJson   Json
  promptVersion     String
  provider          String
  model             String
  inputTokens       Int?
  outputTokens      Int?
  errorMessage      String?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  requestedBy   User          @relation("RequestedAiReports", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([requestedByUserId])
  @@index([reportType])
  @@index([status])
  @@index([periodStart])
  @@index([periodEnd])
  @@index([createdAt])
}

model ExternalPlayerLink {
  id              String         @id @default(cuid())
  playerProfileId String
  source          ExternalSource
  externalId      String
  externalUrl     String
  displayName     String?
  syncEnabled     Boolean        @default(true)
  lastSyncedAt    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  playerProfile PlayerProfile      @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  importJobs    ExternalImportJob[]

  @@unique([playerProfileId, source])
  @@index([playerProfileId])
  @@index([source])
  @@index([syncEnabled])
}

model ExternalImportJob {
  id                   String          @id @default(cuid())
  externalPlayerLinkId String
  status               ImportJobStatus @default(QUEUED)
  startedAt            DateTime?
  completedAt          DateTime?
  matchesImported      Int             @default(0)
  matchesSkipped       Int             @default(0)
  statsImported        Boolean         @default(false)
  errorMessage         String?
  logJson              Json?
  createdAt            DateTime        @default(now())

  externalLink ExternalPlayerLink @relation(fields: [externalPlayerLinkId], references: [id], onDelete: Cascade)

  @@index([externalPlayerLinkId])
  @@index([status])
  @@index([createdAt])
}

enum AnnouncementType {
  RELEASE_NOTE @map("release_note")
  ANNOUNCEMENT @map("announcement")
  MAINTENANCE  @map("maintenance")
}

enum AnnouncementSeverity {
  INFO     @map("info")
  WARNING  @map("warning")
  CRITICAL @map("critical")
}

model Announcement {
  id              String               @id @default(cuid())
  type            AnnouncementType     @default(ANNOUNCEMENT)
  severity        AnnouncementSeverity @default(INFO)
  title           String
  bodyMarkdown    String
  version         String?
  isPublished     Boolean              @default(false)
  publishedAt     DateTime?
  startsAt        DateTime?
  endsAt          DateTime?
  dismissible     Boolean              @default(true)
  createdByUserId String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  createdBy  User                    @relation("AuthoredAnnouncements", fields: [createdByUserId], references: [id], onDelete: Cascade)
  dismissals AnnouncementDismissal[]

  @@index([isPublished])
  @@index([publishedAt])
  @@index([startsAt])
  @@index([endsAt])
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  userId         String
  dismissedAt    DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  actorUserId  String
  action       String
  targetType   String?
  targetId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  actor User @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([action])
  @@index([createdAt])
}

enum SensitiveDataType {
  LIFESTYLE
  SUPPLEMENT
}

enum SensitiveDataAccessAction {
  READ
  CREATE
  UPDATE
  DELETE
}

// Audit trail for access to sensitive wellness/supplement data (per TZ §16.3).
// Records who (actor) touched whose (player profile) sensitive data, how, and
// when — including AI report generation that ships this data to a provider.
model SensitiveDataAccessLog {
  id              String                    @id @default(cuid())
  actorUserId     String
  playerProfileId String
  dataType        SensitiveDataType
  action          SensitiveDataAccessAction
  targetId        String?
  metadataJson    Json?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime                  @default(now())

  actor   User          @relation("SensitiveDataActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  profile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([actorUserId])
  @@index([dataType])
  @@index([createdAt])
}

// --- Profile sharing / delegated access (roles & permissions) -------------
// A PlayerProfile is a "cabinet". Its owner (PlayerProfile.userId) can invite
// other users (coach / parent / guest) to view or edit the cabinet's data.
// Sensitive wellness data is gated by an extra `canAccessWellness` flag.

enum MembershipRelationship {
  COACH
  PARENT
  GUEST
}

enum AccessLevel {
  VIEW
  EDIT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
  EXPIRED
}

// A user's standing access to another player's cabinet.
model ProfileMembership {
  id                String                 @id @default(cuid())
  playerProfileId   String
  userId            String
  relationship      MembershipRelationship
  accessLevel       AccessLevel            @default(VIEW)
  canAccessWellness Boolean                @default(false)
  invitedByUserId   String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([playerProfileId, userId])
  @@index([userId])
  @@index([playerProfileId])
}

// A pending (or resolved) invitation to join a cabinet, delivered by email.
model ProfileInvitation {
  id                String                 @id @default(cuid())
  playerProfileId   String
  email             String
  relationship      MembershipRelationship
  accessLevel       AccessLevel            @default(VIEW)
  canAccessWellness Boolean                @default(false)
  tokenHash         String                 @unique
  status            InvitationStatus       @default(PENDING)
  invitedByUserId   String
  expiresAt         DateTime
  acceptedByUserId  String?
  acceptedAt        DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([email])
  @@index([status])
}

// NOTE: Shot-by-shot, AI insights and external imports will be added in
// subsequent migrations. Schema sketches live in docs/database-model.md.
