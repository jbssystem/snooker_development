// Snooker Player Development OS — Prisma schema (initial skeleton)
// See docs/database-model.md for the full mapping to the TZ entities.
// Migrations are added incrementally per feature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum RoleType {
  PLAYER
  COACH
  PARENT
  ACADEMY_ADMIN
  SYSTEM_ADMIN
}

enum DominantHand {
  LEFT
  RIGHT
  AMBIDEXTROUS
}

enum DrillCategory {
  CUE_ACTION        @map("cue_action")
  POTTING           @map("potting")
  POSITIONAL_PLAY   @map("positional_play")
  BREAK_BUILDING    @map("break_building")
  SAFETY            @map("safety")
  SNOOKER_ESCAPE    @map("snooker_escape")
  TACTICAL_PLAY     @map("tactical_play")
  MATCH_SIMULATION  @map("match_simulation")
  PRESSURE_TRAINING @map("pressure_training")
  MENTAL_ROUTINE    @map("mental_routine")
  CUSTOM            @map("custom")
}

enum DrillDifficulty {
  BEGINNER     @map("beginner")
  INTERMEDIATE @map("intermediate")
  ADVANCED     @map("advanced")
  PROFESSIONAL @map("professional")
}

enum DrillVisibility {
  PRIVATE @map("private")
  SHARED  @map("shared")
  SYSTEM  @map("system")
}

enum TrainingSessionType {
  SOLO       @map("solo")
  COACHED    @map("coached")
  MATCH_PREP @map("match_prep")
  REVIEW     @map("review")
  OTHER      @map("other")
}

enum DrillAttemptResult {
  SUCCESS @map("success")
  PARTIAL @map("partial")
  MISS    @map("miss")
  SKIPPED @map("skipped")
}

enum MatchResult {
  PLAYER_WIN   @map("player_win")
  OPPONENT_WIN @map("opponent_win")
  DRAW         @map("draw")
  UNKNOWN      @map("unknown")
}

enum MatchSource {
  MANUAL   @map("manual")
  EXTERNAL @map("external")
}

enum FrameWinner {
  PLAYER   @map("player")
  OPPONENT @map("opponent")
  UNKNOWN  @map("unknown")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  displayName  String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lastLoginAt  DateTime?

  roles                   Role[]
  refreshTokens           RefreshToken[]
  playerProfile           PlayerProfile?
  coachProfile            CoachProfile?
  drillTemplates          DrillTemplate[]   @relation("CreatedDrillTemplates")
  createdTrainingSessions TrainingSession[] @relation("CreatedTrainingSessions")
  createdMatches          Match[]           @relation("CreatedMatches")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id        String   @id @default(cuid())
  userId    String
  roleType  RoleType
  scopeType String?
  scopeId   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleType])
}

model PlayerProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  firstName    String
  lastName     String
  dateOfBirth  DateTime?
  country      String?
  dominantHand DominantHand?
  level        String?
  seasonGoal   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment        EquipmentProfile[]
  trainingSessions TrainingSession[]
  drillExecutions  DrillExecution[]
  matches          Match[]
}

model EquipmentProfile {
  id              String    @id @default(cuid())
  playerProfileId String
  cueName         String?
  cueWeight       Float?
  tipBrand        String?
  tipSize         Float?
  tipChangeDate   DateTime?
  extension       String?
  chalk           String?
  notes           String?
  activeFrom      DateTime  @default(now())
  activeTo        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([activeFrom])
  @@index([activeTo])
}

model CoachProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  country        String?
  certifications String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DrillTemplate {
  id                     String          @id @default(cuid())
  name                   String
  category               DrillCategory
  difficulty             DrillDifficulty
  description            String
  goal                   String
  rules                  String
  successCriteria        String
  metricsSchemaJson      Json
  defaultTableLayoutJson Json?
  tags                   String[]        @default([])
  visibility             DrillVisibility @default(PRIVATE)
  createdByUserId        String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  createdBy  User             @relation("CreatedDrillTemplates", fields: [createdByUserId], references: [id], onDelete: Cascade)
  executions DrillExecution[]

  @@index([createdByUserId])
  @@index([category])
  @@index([difficulty])
  @@index([visibility])
  @@index([createdAt])
}

model TrainingSession {
  id              String              @id @default(cuid())
  playerProfileId String
  createdByUserId String
  startedAt       DateTime            @default(now())
  endedAt         DateTime?
  sessionType     TrainingSessionType @default(SOLO)
  title           String
  goal            String?
  intensity       Int?
  fatigueBefore   Int?
  fatigueAfter    Int?
  focusLevel      Int?
  mood            String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  playerProfile   PlayerProfile    @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy       User             @relation("CreatedTrainingSessions", fields: [createdByUserId], references: [id], onDelete: Cascade)
  drillExecutions DrillExecution[]

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([startedAt])
  @@index([endedAt])
}

model DrillExecution {
  id                      String    @id @default(cuid())
  trainingSessionId       String
  drillTemplateId         String
  playerProfileId         String
  startedAt               DateTime  @default(now())
  endedAt                 DateTime?
  attempts                Int       @default(0)
  successes               Int       @default(0)
  score                   Float?
  maxRun                  Int?
  averageScore            Float?
  resultJson              Json?
  errorTags               String[]  @default([])
  coachNotes              String?
  playerNotes             String?
  tableLayoutSnapshotJson Json?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  trainingSession TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)
  drillTemplate   DrillTemplate   @relation(fields: [drillTemplateId], references: [id], onDelete: Restrict)
  playerProfile   PlayerProfile   @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  attemptsLog     DrillAttempt[]

  @@index([trainingSessionId])
  @@index([drillTemplateId])
  @@index([playerProfileId])
  @@index([startedAt])
  @@index([endedAt])
}

model DrillAttempt {
  id               String             @id @default(cuid())
  drillExecutionId String
  attemptNumber    Int
  result           DrillAttemptResult
  score            Float?
  potSuccess       Boolean?
  positionSuccess  Boolean?
  missType         String?
  errorTags        String[]           @default([])
  shotTimeMs       Int?
  notes            String?
  createdAt        DateTime           @default(now())

  drillExecution DrillExecution @relation(fields: [drillExecutionId], references: [id], onDelete: Cascade)

  @@unique([drillExecutionId, attemptNumber])
  @@index([drillExecutionId])
  @@index([createdAt])
}

model Match {
  id                  String       @id @default(cuid())
  playerProfileId     String
  createdByUserId     String
  matchDate           DateTime     @default(now())
  tournament          String?
  country             String?
  city                String?
  club                String?
  opponentName        String
  opponentExternalId  String?
  round               String?
  format              String?
  framesWon           Int          @default(0)
  framesLost          Int          @default(0)
  highBreak           Int?
  breaks50            Int          @default(0)
  breaks70            Int          @default(0)
  breaks100           Int          @default(0)
  decidingFrameResult FrameWinner?
  safetySuccess       Float?
  longPotSuccess      Float?
  unforcedErrors      Int?
  tacticalErrors      Int?
  result              MatchResult  @default(UNKNOWN)
  source              MatchSource  @default(MANUAL)
  sourceUrl           String?
  videoUrl            String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  playerProfile PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)
  createdBy     User          @relation("CreatedMatches", fields: [createdByUserId], references: [id], onDelete: Cascade)
  frames        MatchFrame[]

  @@index([playerProfileId])
  @@index([createdByUserId])
  @@index([matchDate])
  @@index([opponentName])
  @@index([result])
}

model MatchFrame {
  id               String      @id @default(cuid())
  matchId          String
  frameNumber      Int
  playerScore      Int?
  opponentScore    Int?
  winner           FrameWinner @default(UNKNOWN)
  highBreak        Int?
  frameDurationSec Int?
  notes            String?
  createdAt        DateTime    @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, frameNumber])
  @@index([matchId])
  @@index([winner])
}

// NOTE: Shot-by-shot, calendar, lifestyle, AI reports and external imports
// will be added in subsequent migrations. Schema sketches live in
// docs/database-model.md.
