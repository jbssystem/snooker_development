// Snooker Player Development OS — Prisma schema (initial skeleton)
// See docs/database-model.md for the full mapping to the TZ entities.
// Migrations are added incrementally per feature.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum RoleType {
  PLAYER
  COACH
  PARENT
  ACADEMY_ADMIN
  SYSTEM_ADMIN
}

enum DominantHand {
  LEFT
  RIGHT
  AMBIDEXTROUS
}

enum DrillCategory {
  CUE_ACTION        @map("cue_action")
  POTTING           @map("potting")
  POSITIONAL_PLAY   @map("positional_play")
  BREAK_BUILDING    @map("break_building")
  SAFETY            @map("safety")
  SNOOKER_ESCAPE    @map("snooker_escape")
  TACTICAL_PLAY     @map("tactical_play")
  MATCH_SIMULATION  @map("match_simulation")
  PRESSURE_TRAINING @map("pressure_training")
  MENTAL_ROUTINE    @map("mental_routine")
  CUSTOM            @map("custom")
}

enum DrillDifficulty {
  BEGINNER     @map("beginner")
  INTERMEDIATE @map("intermediate")
  ADVANCED     @map("advanced")
  PROFESSIONAL @map("professional")
}

enum DrillVisibility {
  PRIVATE @map("private")
  SHARED  @map("shared")
  SYSTEM  @map("system")
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  displayName  String
  status       UserStatus  @default(ACTIVE)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  lastLoginAt  DateTime?

  roles         Role[]
  refreshTokens RefreshToken[]
  playerProfile PlayerProfile?
  coachProfile  CoachProfile?
  drillTemplates DrillTemplate[] @relation("CreatedDrillTemplates")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id        String   @id @default(cuid())
  userId    String
  roleType  RoleType
  scopeType String?
  scopeId   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleType])
}

model PlayerProfile {
  id             String        @id @default(cuid())
  userId         String        @unique
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  country        String?
  dominantHand   DominantHand?
  level          String?
  seasonGoal     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment      EquipmentProfile[]
}

model EquipmentProfile {
  id              String        @id @default(cuid())
  playerProfileId String
  cueName         String?
  cueWeight       Float?
  tipBrand        String?
  tipSize         Float?
  tipChangeDate   DateTime?
  extension       String?
  chalk           String?
  notes           String?
  activeFrom      DateTime      @default(now())
  activeTo        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  playerProfile   PlayerProfile @relation(fields: [playerProfileId], references: [id], onDelete: Cascade)

  @@index([playerProfileId])
  @@index([activeFrom])
  @@index([activeTo])
}

model CoachProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  displayName    String
  country        String?
  certifications String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DrillTemplate {
  id                     String           @id @default(cuid())
  name                   String
  category               DrillCategory
  difficulty             DrillDifficulty
  description            String
  goal                   String
  rules                  String
  successCriteria        String
  metricsSchemaJson      Json
  defaultTableLayoutJson Json?
  tags                   String[]         @default([])
  visibility             DrillVisibility  @default(PRIVATE)
  createdByUserId        String
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  createdBy              User             @relation("CreatedDrillTemplates", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([createdByUserId])
  @@index([category])
  @@index([difficulty])
  @@index([visibility])
  @@index([createdAt])
}

// NOTE: Training sessions, drills, matches, frames, shots, calendar,
// lifestyle, equipment, AI reports and external imports will be added
// in subsequent migrations. Schema sketches live in docs/database-model.md.
