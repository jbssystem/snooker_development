# ===== Production identity =====
NODE_ENV=production
APP_NAME=snooker-player-os
DEFAULT_LOCALE=ru
PUBLIC_APP_URL=https://snooker.appshub.pl

# Host port for the app nginx container. Keep loopback when a host nginx
# terminates TLS and proxies snooker.appshub.pl to this container.
APP_HTTP_BIND=127.0.0.1:3300

# ===== Web =====
WEB_PORT=3000
NEXT_PUBLIC_API_URL=/api

# ===== API =====
API_PORT=4000
API_JWT_SECRET=replace-with-a-long-random-secret
CORS_ORIGINS=https://snooker.appshub.pl
AUTH_REFRESH_COOKIE_PATH=/api/auth
AUTH_REFRESH_COOKIE_SECURE=true

# ===== PostgreSQL =====
POSTGRES_DB=snooker_os
POSTGRES_USER=snooker
POSTGRES_PASSWORD=replace-with-a-long-random-password

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== MinIO / S3 =====
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=snooker-attachments
S3_ACCESS_KEY=replace-with-minio-access-key
S3_SECRET_KEY=replace-with-minio-secret-key

# ===== AI =====
# Supported: anthropic | openai | local | none
AI_PROVIDER=none
AI_API_KEY=
AI_MODEL=claude-3-5-sonnet-latest